# ========================================
# NHSO API Configuration (สปสช)
# ========================================
# URL ของ API สปสช (ใช้ค่าเริ่มต้นนี้ หรือติดต่อ สปสช เพื่อขอ URL จริง)
NHSO_API_URL=https://ucws.nhso.go.th/ucwstokenp1/UCWSTokenP1

# Token สำหรับเชื่อมต่อ API สปสช (ต้องขอจาก สปสช)
# ⚠️ ห้ามแชร์หรือ commit token จริงลง Git
NHSO_TOKEN=your_nhso_token_here

# ========================================
# Card Reader Service Configuration
# ========================================
# URL ของ Card Reader Service (รันบน localhost)
CARD_READER_URL=http://localhost:8080

# ========================================
# Database Configuration (ถ้ามี)
# ========================================
# ถ้าต้องการใช้ MySQL แทน SQLite
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=sso_db

# ========================================
# Application Configuration
# ========================================
# PORT สำหรับ Next.js (default: 3000)
# PORT=3000

# Environment (development, production)
NODE_ENV=development
